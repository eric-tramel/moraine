<clickhouse>
  <profiles>
    <default>
      <use_concurrency_control>1</use_concurrency_control>
      <!-- Per-query backstop (4 GiB) with spill at half that; Moraine's
           query envelope sends tighter per-statement budgets, so these only
           catch statements issued without one. -->
      <max_memory_usage>4294967296</max_memory_usage>
      <max_bytes_before_external_group_by>2147483648</max_bytes_before_external_group_by>
      <max_bytes_before_external_sort>2147483648</max_bytes_before_external_sort>
      <load_balancing>random</load_balancing>
    </default>
  </profiles>

  <users>
    <default>
      <password></password>
      <profile>default</profile>
      <quota>default</quota>
      <networks>
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
      </networks>
      <access_management>1</access_management>
    </default>
  </users>

  <quotas>
    <default>
      <interval>
        <duration>3600</duration>
        <queries>0</queries>
        <errors>0</errors>
        <result_rows>0</result_rows>
        <read_rows>0</read_rows>
        <execution_time>0</execution_time>
      </interval>
    </default>
  </quotas>
</clickhouse>
